{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "featuredField": "image",
      "pageBundle": false,
      "previewPath": null,
      "fields": [
        {
          "title": "layout",
          "name": "layout",
          "default": "post",
          "type": "string"
        },
        {
          "title": "Title",
          "name": "title",
          "type": "string"
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        },
        {
          "title": "Publishing date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "dateFormat": "yy-MM-dd",
          "isPublishDate": true
        },
        {
          "title": "author",
          "name": "author",
          "type": "string"
        },
        {
          "title": "slug",
          "name": "slug",
          "default": "{{slug}}",
          "type": "string"
        },
        {
          "title": "canonical_url",
          "name": "canonical_url",
          "default": "https://holgerimbery.blog/{{slug}}",
          "type": "string"
        },
        {
          "title": "image",
          "name": "image",
          "type": "image"
        },
        {
          "title": "image_caption",
          "name": "image_caption",
          "type": "string"
        },
        {
          "title": "Tags",
          "name": "tags",
          "type": "tags"
        },
        {
          "title": "featured",
          "name": "featured",
          "type": "boolean"
        },
        {
          "title": "toc",
          "name": "toc",
          "type": "boolean"
        }
      ]
    }
  ],
  "frontMatter.preview.host": "http://127.0.0.1:4000",
  "frontMatter.content.pageFolders": [
    {
      "title": "drafts",
      "path": "[[workspace]]/_drafts"
    },
    {
      "title": "posts",
      "path": "[[workspace]]/_posts"
    },
    {
      "path": "[[workspace]]/_pages",
      "title": "pages"
    }
  ],
  "frontMatter.content.mediaFolders": [
    {
      "title": "Images",
      "path": "images"
    }
  ],
  "frontMatter.website.host": "https://holgerimbery.blog",
  "frontMatter.dashboard.openOnStart": true,
  "frontMatter.panel.openOnSupportedFile": true,
  "frontMatter.framework.startCommand": "bundle exec jekyll serve --livereload --future",
  "frontMatter.snippets.wrapper.enabled": false,
  "frontMatter.extensibility.scripts": [
    "[[workspace]]/.frontmatter/ui/external.js"
  ],
  "frontMatter.content.snippets": {
    "Callout": {
      "description": "Creates a callout box",
      "body": [
        "{: .[[type]] }",
        "[[selection]]"
      ],
      "fields": [
        {
          "name": "type",
          "title": "Type",
          "type": "choice",
          "choices": [
            "note",
            "tip",
            "important",
            "warning",
            "caution"
          ],
          "default": "note"
        },
        {
          "name": "selection",
          "title": "Selection",
          "type": "string",
          "default": "FM_SELECTED_TEXT"
        }
      ]
    }, 
      "highlightbox": {
      "description": "Creates a highlighted box with a left border",
      "body": [
        "{: .q-left }",
        "> [[selection]]"
      ],
      "fields": [
        {
          "name": "selection",
          "title": "Selection",
          "type": "string",
          "default": "FM_SELECTED_TEXT"
        }
      ]
    }

  }
}